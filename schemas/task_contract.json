{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TaskContract",
  "type": "object",
  "required": [
    "task_id",
    "role",
    "objective",
    "constraints",
    "acceptance_criteria",
    "definition_of_done",
    "priority",
    "risk_level",
    "status"
  ],
  "properties": {
    "task_id": {
      "type": "string"
    },
    "role": {
      "type": "string"
    },
    "assigned_agent": {
      "type": "string"
    },
    "linked_prd": {
      "type": "string"
    },
    "objective": {
      "type": "string"
    },
    "constraints": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "out_of_scope": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "acceptance_criteria": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "definition_of_done": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "priority": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical"]
    },
    "risk_level": {
      "type": "string",
      "enum": ["low", "medium", "high"]
    },
    "status": {
      "type": "string",
      "enum": ["not_started", "in_progress", "blocked", "in_review", "done"]
    },
    "likely_files": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "requires_security_review": {
      "type": "boolean"
    },
    "requires_migration": {
      "type": "boolean"
    },
    "requires_docs_update": {
      "type": "boolean"
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
