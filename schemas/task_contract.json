{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TaskContract",
  "type": "object",
  "required": ["task_id", "role", "objective", "constraints", "acceptance_criteria"],
  "properties": {
    "task_id": {"type": "string"},
    "role": {"type": "string"},
    "objective": {"type": "string"},
    "constraints": {"type": "array", "items": {"type": "string"}},
    "acceptance_criteria": {"type": "array", "items": {"type": "string"}},
    "likely_files": {"type": "array", "items": {"type": "string"}},
    "requires_security_review": {"type": "boolean"},
    "requires_migration": {"type": "boolean"},
    "requires_docs_update": {"type": "boolean"}
  }
}
